.venv/
.worktrees/
__pycache__/
*.pyc
.DS_Store

# Local outputs/logs (keep repo light)
outputs/**/*
processed/**/*
logs/**/*
!outputs/.gitkeep
!processed/.gitkeep
!logs/.gitkeep


# bv (beads viewer) local config and caches
.bv/

# Local vendored build metadata (not source), except tracked OpenBabel meta-package.
vendor/*
!vendor/openbabel_meta/
vendor/openbabel_meta/*
!vendor/openbabel_meta/pyproject.toml
!vendor/openbabel_meta/README.md
vendor/openbabel_meta/*.egg-info/
